# docker-compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=stoat_bootstrap     # プロジェクト名(全て小文字)
CONTAINER_NAME=stoat_bootstrap

Dockerfile_DIR=.
Dockerfile=Dockerfile

# HOST_PROJECT_DIR は compose.yml 側で ${PWD}(実行時のカレントディレクトリ)から
# 自動的に決まるので、ここで手動設定する必要はありません。
# 必ずこの Stoat フォルダの中で "docker compose up" を実行してください。

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

# ---- Stoat固有設定 ----
# クローン先(実行時のカレントディレクトリ配下に作られる)
REPO_URL=https://github.com/stoatchat/self-hosted.git
REPO_DIR=stoat

# 公開予定のドメイン/ホスト名
DOMAIN=raspi5.lan

# generate_config.sh への自動回答
# ENABLE_REVERSE_PROXY=y -> nginx側で証明書/ルーティングを管理する構成(Caddyは:8880のみでLISTEN)
# ENABLE_VIDEO=y         -> カメラ/画面共有を有効化 (不要なら n)
ENABLE_REVERSE_PROXY=y
ENABLE_VIDEO=y
